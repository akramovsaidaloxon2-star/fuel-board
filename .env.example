# Local development: copy this file to ".env" and fill in real values.
# On the cloud host (Render), DO NOT use a .env file — set these as
# environment variables in the dashboard instead.

# Your Motive API key (kept secret, never committed):
MOTIVE_API_KEY=your-motive-api-key-here

# Port (local only; Render sets this automatically):
PORT=3000

# Login for the board. Leave both empty for no login (local).
# Set both on the cloud host to require a username + password:
AUTH_USER=admin
AUTH_PASS=change-me-to-a-strong-password
